{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://umg.envoy/schemas/neoblock.schema.json",
  "title": "UMG NeoBlock Schema v0.1",
  "description": "Validating schema for a UMG NeoBlock composed from MOLT blocks and structured references.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "identity": {
      "$ref": "./artifact.identity.schema.json"
    },
    "provenance": {
      "$ref": "./provenance.schema.json"
    },
    "neoblock": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "description": { "type": ["string", "null"] },
        "status": {
          "type": "string",
          "enum": ["active", "deprecated", "experimental", "archived"]
        },
        "version": {
          "type": "string",
          "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
        },
        "category": {
          "type": "string",
          "enum": ["general", "domain_specific", "framework_specific", "experimental", "archived"]
        },
        "tags": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "composition": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "molt_block_ids": {
              "type": "array",
              "items": { "type": "string", "minLength": 1 },
              "uniqueItems": true
            },
            "ordered_steps": {
              "type": "array",
              "items": {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                  "id": { "type": ["string", "null"] },
                  "uses": { "type": "array", "items": { "type": "string" }, "uniqueItems": true },
                  "mode": { "type": ["string", "null"], "enum": ["serial", "parallel", "conditional", null] },
                  "condition": { "type": ["string", "object", "null"] },
                  "notes": { "type": ["string", "null"] }
                }
              }
            },
            "merge_rules": {
              "type": "array",
              "items": { "type": ["string", "object"] }
            }
          },
          "required": ["molt_block_ids"]
        },
        "molt_roles": {
          "type": "object",
          "additionalProperties": {
            "type": "array",
            "items": { "type": "string" },
            "uniqueItems": true
          }
        },
        "geometry": {
          "type": ["object", "null"],
          "additionalProperties": false,
          "properties": {
            "x": { "type": ["number", "null"] },
            "y": { "type": ["number", "null"] },
            "width": { "type": ["number", "null"], "minimum": 0 },
            "height": { "type": ["number", "null"], "minimum": 0 },
            "group": { "type": ["string", "null"] },
            "layer": { "type": ["integer", "null"] }
          }
        },
        "capabilities": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "governance": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "directive_ids": {
              "type": "array",
              "items": { "type": "string" },
              "uniqueItems": true
            },
            "policy_links": {
              "type": "array",
              "items": { "type": "string" },
              "uniqueItems": true
            },
            "route_constraints": {
              "type": "array",
              "items": { "type": ["string", "object"] }
            }
          }
        },
        "examples": {
          "type": "array",
          "items": { "type": ["object", "string"] }
        },
        "notes": { "type": ["string", "null"] }
      },
      "required": [
        "name",
        "status",
        "version",
        "category",
        "composition"
      ]
    },
    "metadata": {
      "type": ["object", "null"],
      "additionalProperties": true
    }
  },
  "required": ["identity", "provenance", "neoblock"]
}
