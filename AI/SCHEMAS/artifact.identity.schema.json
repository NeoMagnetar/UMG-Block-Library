{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://umg.envoy/schemas/artifact.identity.schema.json",
  "title": "UMG Artifact Identity Schema v0.1",
  "description": "Identity contract for packageable UMG artifacts.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "artifact_id": {
      "type": "string",
      "pattern": "^[A-Z0-9._-]+\\.v[0-9]+$"
    },
    "artifact_type": {
      "type": "string",
      "enum": [
        "molt_block",
        "neoblock",
        "neostack",
        "sleeve",
        "bundle",
        "overlay",
        "toolpack",
        "capability",
        "schema",
        "example",
        "fixture"
      ]
    },
    "human_library_code": {
      "type": ["string", "null"],
      "pattern": "^[0-9]{3}$"
    },
    "content_hash": {
      "type": ["string", "null"],
      "pattern": "^(sha256:)?[a-fA-F0-9]{64}$"
    },
    "package_hash": {
      "type": ["string", "null"],
      "pattern": "^(sha256:)?[a-fA-F0-9]{64}$"
    },
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    }
  },
  "required": [
    "artifact_id",
    "artifact_type",
    "version"
  ]
}
